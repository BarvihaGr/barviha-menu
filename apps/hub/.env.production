# Публичный (браузерный) адрес приложения меню — бэк-офис показывает
# превью фото по абсолютной ссылке на apps/menu (два разных Next-сервера/
# порта на одном хосте). Без этого в браузере подставлялся дефолт
# http://localhost:3000, который у постороннего пользователя указывает
# на его собственную машину — все превью фото были битыми.
# NEXT_PUBLIC_* инлайнится в сборку на этапе build, не runtime — при смене
# домена нужен пересбор (next build), а не просто рестарт процесса.
NEXT_PUBLIC_MENU_ORIGIN=https://menu.barvikhagroup.ru
