{
  "name": "barviha",
  "version": "0.1.0",
  "private": true,
  "description": "Barviha Lounge — digital menu platform (monorepo)",
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "pnpm --filter @barviha/menu dev",
    "build": "pnpm --filter @barviha/menu build",
    "start": "pnpm --filter @barviha/menu start",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r exec rm -rf .next dist node_modules && rm -rf node_modules"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
